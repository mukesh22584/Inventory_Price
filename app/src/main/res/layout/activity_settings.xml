<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/dodger_blue"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

              <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="App Icon" />

            <TextView
                android:id="@+id/settings_app_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Know Your Cost, Secure Your Profit"
                android:textSize="14sp"
                android:alpha="0.8"
                android:textColor="?android:attr/textColorSecondary"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <LinearLayout
            android:id="@+id/btn_theme_header"
            style="@style/SettingsRowStyle">
          <LinearLayout
            style="@style/SettingsTextStyle">
            <TextView style="@style/SettingsTitleStyle" android:text="Theme" />
            <TextView style="@style/SettingsSubtitleStyle" android:text="Light, dark, system default" />
          </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/theme_options_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#10ffffff"
            android:paddingStart="16dp">
            <TextView android:id="@+id/btn_theme_light" style="@style/SettingsRowStyle" android:text="Light" android:textSize="14sp" />
            <TextView android:id="@+id/btn_theme_dark" style="@style/SettingsRowStyle" android:text="Dark" android:textSize="14sp" />
            <TextView android:id="@+id/btn_theme_system" style="@style/SettingsRowStyle" android:text="System Default" android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/divider" />

        <LinearLayout
            android:id="@+id/btn_backup_settings"
            style="@style/SettingsRowStyle">
          <LinearLayout
            style="@style/SettingsTextStyle">
            <TextView style="@style/SettingsTitleStyle" android:text="Backup" />
            <TextView style="@style/SettingsSubtitleStyle" android:text="Create a local database backup" />
          </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/divider" />

        <LinearLayout
            android:id="@+id/btn_restore_settings"
            style="@style/SettingsRowStyle">
          <LinearLayout style="@style/SettingsTextStyle">
            <TextView style="@style/SettingsTitleStyle" android:text="Restore" />
            <TextView style="@style/SettingsSubtitleStyle" android:text="Restore data from a backup file" />
          </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/divider" />

        <LinearLayout
            android:id="@+id/btn_about_header"
            style="@style/SettingsRowStyle">
          <LinearLayout style="@style/SettingsTextStyle">
            <TextView style="@style/SettingsTitleStyle" android:text="About the app" />
            <TextView style="@style/SettingsSubtitleStyle" android:text="Links and app details" />
          </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/about_options_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#10ffffff"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/btn_changelog"
                style="@style/SettingsRowStyle"
                android:text="Release and changelog"
                android:textSize="14sp" />
                
            <TextView
                android:id="@+id/btn_view_source"
                style="@style/SettingsRowStyle"
                android:text="View source code"
                android:textSize="14sp" />

			<TextView
				android:id="@+id/btn_share_app"
				style="@style/SettingsRowStyle"
				android:text="Share app"
				android:textSize="14sp" />

		</LinearLayout>

		</LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_margin="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            style="@style/SettingsTitleStyle"
                            android:text="Enable Size Field" />
                        <TextView
                            style="@style/SettingsSubtitleStyle"
                            android:text="Show or Hide size details" />
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_size_visibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
						app:thumbTint="@color/dodger_blue"
						app:trackTint="#BDBDBD" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
				      android:layout_width="match_parent"
				      android:layout_height="wrap_content"
				      android:layout_margin="16dp">

        <LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:padding="20dp">

			<TextView
				style="@style/SettingsTitleStyle"
				android:text="Shop Statistics"
				android:textColor="@color/dodger_blue" />

			<TextView
				android:id="@+id/app_total_items_count"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:text="Total Products: 0"
				android:textSize="14sp"
				android:textStyle="bold" />

			<TextView
				android:id="@+id/app_database_size"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:text="Database Size: 0 KB"
				android:textSize="13sp"
				android:alpha="0.7" />

        	<TextView
				android:id="@+id/app_backup_status"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:text="Last Backup: Never"
				android:textSize="13sp"
				android:alpha="0.7" />
        </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
				android:layout_width="match_parent"
    			android:layout_height="wrap_content"
    			android:layout_margin="16dp"
    			app:strokeColor="#FF0000"
    			app:strokeWidth="1dp">

        <LinearLayout
			android:id="@+id/btn_reset_data"
			style="@style/SettingsRowStyle"
			android:background="@android:color/transparent">

			<LinearLayout
				style="@style/SettingsTextStyle">
            <TextView
                style="@style/SettingsTitleStyle"
                android:text="Delete All Data"
                android:textColor="#FF0000" />
            <TextView
                style="@style/SettingsSubtitleStyle"
                android:text="Permanently remove all products and details." />
			</LinearLayout>
        </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="24dp"
                android:text="Handcrafted for Performance by Mukesh Singh"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:fontFamily="sans-serif-light"
                android:alpha="0.7" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
